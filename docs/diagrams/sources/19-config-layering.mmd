graph TB
    D["pydantic defaults<br/>(DeepViewConfig field defaults)"]:::layer1
    T["~/.deepview/config.toml<br/>(validated: no symlinks,<br/>size-limited, TOML parse)"]:::layer2
    E["DEEPVIEW_*__ env vars<br/>(nested keys via __ delimiter)"]:::layer3
    C["CLI flag overrides<br/>(--log-level, --config, ...)"]:::layer4
    F["final DeepViewConfig instance<br/>(attached to AnalysisContext.config)"]:::final

    D -->|base| T
    T -->|override| E
    E -->|override| C
    C -->|materialize| F

    VAL["_validate_config_file<br/>- rejects symlinks<br/>- rejects oversized files<br/>- rejects unreadable paths"]:::guard
    T -.gates.- VAL

