graph TB
    CLI["CLI<br/>(Click + Rich)"]:::core
    CTX["AnalysisContext"]:::core

    subgraph Core["Core Framework"]
        CTX
        EB["EventBus<br/>(pub/sub)"]:::core
        CFG["DeepViewConfig<br/>(pydantic)"]:::core
        PR["PluginRegistry<br/>(3-tier discovery)"]:::core
        PLT["PlatformInfo<br/>(detect)"]:::core
    end

    subgraph Memory["Memory Forensics"]
        MM["MemoryManager"]:::analysis
        ACQ["Acquisition<br/>LiME | AVML | WinPmem | OSXPmem"]:::source
        FMT["Format parsers<br/>raw | LiME | ELF core | crashdump"]:::analysis
        VOL["Volatility 3 / MemProcFS"]:::analysis
    end

    subgraph Storage["Storage Subsystem (new)"]
        SM["StorageManager"]:::storage
        FMTS["formats (raw, MTD, UBI)"]:::storage
        ECC["ecc (BCH, Hamming, Reed-Solomon)"]:::storage
        FTL["ftl (linearized, block map)"]:::storage
        ENC["encodings (compression)"]:::storage
        FS["filesystems (FAT, ext, APFS, tsk)"]:::storage
        PART["partition (MBR / GPT)"]:::storage
        CT["containers (LUKS / BitLocker / VeraCrypt / FileVault2)"]:::storage
        AUTO["auto<br/>(orchestrates wrap+probe)"]:::storage
    end

    subgraph Offload["Offload Subsystem (new)"]
        OE["OffloadEngine"]:::offload
        THB["ThreadPoolBackend"]:::offload
        PPB["ProcessPoolBackend<br/>(default)"]:::offload
        GCL["OpenCLBackend"]:::offload
        GCU["CUDABackend"]:::offload
        RWB["RemoteWorkerBackend"]:::offload
        KDF["KDF dispatch<br/>(pbkdf2_sha256 | argon2id)"]:::offload
    end

    subgraph Remote["Remote Acquisition (new)"]
        REP["RemoteEndpoint"]:::remote
        FAC["factory.build_remote_provider"]:::remote
        SSH["SSH-DD"]:::remote
        TCP["TCP / UDP / agent"]:::remote
        DMA["DMA Thunderbolt / PCIe / FireWire"]:::remote
        IPMI["IPMI / Intel AMT"]:::remote
    end

    subgraph Tracing["Tracing"]
        TM["TraceManager"]:::instrument
        PROV["eBPF | DTrace | ETW"]:::instrument
    end

    subgraph Instrument["Instrumentation"]
        IM["Frida + binary reassembly"]:::instrument
    end

    subgraph VM["VM Introspection"]
        VMM["QEMU | VBox | VMware | LibVMI"]:::analysis
    end

    subgraph Detection["Detection"]
        DET["anti-forensics | injection | keys | anomaly | rootkit"]:::detect
    end

    subgraph Reporting["Reporting"]
        RE["HTML / Markdown / JSON / STIX / ATT&CK"]:::report
    end

    CLI --> CTX
    CTX --> EB
    CTX --> CFG
    CTX --> PR
    CTX --> PLT
    CTX --> MM
    CTX --> SM
